Scripts para setup, diagnóstico e manutenção de servidores backend.

## orion-vm-setup.sh

Diagnóstico completo da VM Orion no Google Cloud Platform.

### O que verifica

- Status do serviço systemd (`orion.service`)
- Variáveis de ambiente injetadas
- Endpoints FastAPI (health, proxy/gemini, embeddings, tts, stt)
- Uso de memória e CPU
- Configuração dos drop-ins do systemd
- Secrets e tokens órfãos

### Uso

```bash
chmod +x orion-vm-setup.sh
./orion-vm-setup.sh
```

### Requisitos

- Ubuntu 22.04+ / Debian
- Python 3.10+
- systemd
- curl, jq
'''

# ── ci-cd/README.md ───────────────────────────────────────────────────────────
files["ci-cd/README.md"] = '''# 🚀 CI/CD

Workflows prontos para GitHub Actions.

## frontend-analysis.yml

Roda o `analyze-frontend.sh` automaticamente em todo push e pull request.

### Funcionalidades

- ✅ Análise completa em modo `--strict`
- ✅ Gera `report.json` como artefato
- ✅ Comenta automaticamente no PR com o score
- ✅ Bloqueia merge se score crítico

### Instalação

```bash
mkdir -p .github/workflows
cp frontend-analysis.yml .github/workflows/
```

### Exemplo de comentário no PR

```
## ✨ Frontend Analysis — Score: 94/100

|                  | Resultado |
|---|---|
| 🔴 Erros críticos | 0 |
| 🟡 Avisos         | 2 |
| 🔵 Sugestões      | 3 |
| ⏱ Tempo          | 12s |
| 🧩 Framework      | Next.js |

> ✅ Pronto para merge.
```
'''

# ── scripts/README.md ─────────────────────────────────────────────────────────
files["scripts/README.md"] = '''# 🔧 Scripts Utilitários

Scripts standalone para tarefas comuns de desenvolvimento.

## env-check.sh

Verifica se todas as variáveis de ambiente necessárias estão definidas.

```bash
# Uso básico
./env-check.sh

# Com arquivo de referência customizado
./env-check.sh --ref .env.production.example

# Modo strict (exit 1 se faltar alguma)
./env-check.sh --strict
```

## deps-check.sh

Verifica saúde das dependências npm/pnpm/yarn/bun.

```bash
# Verificar vulnerabilidades + outdated
./deps-check.sh

# Só vulnerabilidades
./deps-check.sh --audit-only

# Só dependências desatualizadas
./deps-check.sh --outdated-only
```
'''

# ── scripts/env-check.sh ─────────────────────────────────────────────────────
files["scripts/env-check.sh"] = '''#!/usr/bin/env bash
# env-check.sh — Verifica variáveis de ambiente obrigatórias
# Uso: ./env-check.sh [--ref <arquivo>] [--strict]

set -euo pipefail
RED=\'\\033[0;31m\'; GREEN=\'\\033[0;32m\'; YELLOW=\'\\033[1;33m\'; RESET=\'\\033[0m\'
STRICT=false; REF_FILE=".env.example"

while [[ $# -gt 0 ]]; do
  case $1 in
    --strict) STRICT=true ;;
    --ref)    REF_FILE="$2"; shift ;;
  esac
  shift
done

ERRORS=0
echo -e "\\n🔍 Verificando variáveis de ambiente..."
echo -e "   Referência: ${REF_FILE}\\n"

if [[ ! -f "$REF_FILE" ]]; then
  echo -e "${YELLOW}⚠  ${REF_FILE} não encontrado — nada a verificar${RESET}"
  exit 0
fi

ENV_FILE=".env"
[[ ! -f "$ENV_FILE" ]] && ENV_FILE=".env.local"
[[ ! -f "$ENV_FILE" ]] && { echo -e "${RED}✖ Nenhum .env encontrado${RESET}"; exit 1; }

while IFS= read -r line; do
  [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue
  VAR=$(echo "$line" | cut -d= -f1)
  if grep -q "^${VAR}=" "$ENV_FILE" 2>/dev/null; then
    VAL=$(grep "^${VAR}=" "$ENV_FILE" | cut -d= -f2-)
    [[ -z "$VAL" ]] && echo -e "${YELLOW}⚠  $VAR está vazia${RESET}" \
                    || echo -e "${GREEN}✔  $VAR${RESET}"
  else
    echo -e "${RED}✖  $VAR não encontrada em ${ENV_FILE}${RESET}"
    ERRORS=$((ERRORS+1))
  fi
done < "$REF_FILE"

echo ""
[[ $ERRORS -gt 0 ]] && echo -e "${RED}$ERRORS variável(is) ausente(s)${RESET}" \
                     || echo -e "${GREEN}✨ Todas as variáveis presentes${RESET}"

[[ "$STRICT" == true && $ERRORS -gt 0 ]] && exit 1
exit 0
'''

# ── scripts/deps-check.sh ────────────────────────────────────────────────────
files["scripts/deps-check.sh"] = '''#!/usr/bin/env bash
# deps-check.sh — Saúde das dependências npm/pnpm/yarn/bun
# Uso: ./deps-check.sh [--audit-only] [--outdated-only]

set -euo pipefail
RED=\'\\033[0;31m\'; GREEN=\'\\033[0;32m\'; YELLOW=\'\\033[1;33m\'
BLUE=\'\\033[0;34m\'; BOLD=\'\\033[1m\'; RESET=\'\\033[0m\'

AUDIT_ONLY=false; OUTDATED_ONLY=false
while [[ $# -gt 0 ]]; do
  case $1 in
    --audit-only)    AUDIT_ONLY=true ;;
    --outdated-only) OUTDATED_ONLY=true ;;
  esac
  shift
done

PM="npm"
[[ -f "yarn.lock" ]]      && PM="yarn"
[[ -f "pnpm-lock.yaml" ]] && PM="pnpm"
[[ -f "bun.lockb" ]]      && PM="bun"

echo -e "\\n${BOLD}🔍 Verificando dependências (${PM})...${RESET}\\n"

if [[ "$OUTDATED_ONLY" == false ]]; then
  echo -e "${BOLD}━━━ Vulnerabilidades${RESET}"
  if [[ "$PM" == "npm" ]]; then
    AUDIT=$(npm audit --json 2>/dev/null || echo "{}")
    C=$(echo "$AUDIT" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get(\'metadata\',{}).get(\'vulnerabilities\',{}).get(\'critical\',0))" 2>/dev/null || echo 0)
    H=$(echo "$AUDIT" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get(\'metadata\',{}).get(\'vulnerabilities\',{}).get(\'high\',0))" 2>/dev/null || echo 0)
    [[ $C -gt 0 ]] && echo -e "${RED}  ✖ $C crítica(s)${RESET}" || true
    [[ $H -gt 0 ]] && echo -e "${YELLOW}  ⚠ $H high${RESET}" || true
    [[ $C -eq 0 && $H -eq 0 ]] && echo -e "${GREEN}  ✔ Sem vulnerabilidades críticas/high${RESET}"
  elif [[ "$PM" == "pnpm" ]]; then
    pnpm audit 2>/dev/null || true
  fi
fi

if [[ "$AUDIT_ONLY" == false ]]; then
  echo -e "\\n${BOLD}━━━ Dependências Desatualizadas${RESET}"
  if [[ "$PM" == "npm" ]]; then
    OUTDATED=$(npm outdated 2>/dev/null || true)
    [[ -n "$OUTDATED" ]] && echo "$OUTDATED" || echo -e "${GREEN}  ✔ Tudo atualizado${RESET}"
  elif [[ "$PM" == "pnpm" ]]; then
    pnpm outdated 2>/dev/null || echo -e "${GREEN}  ✔ Tudo atualizado${RESET}"
  fi
fi

echo ""
'''

# ── ci-cd/github-actions/frontend-analysis.yml ───────────────────────────────
files["ci-cd/github-actions/frontend-analysis.yml"] = '''name: 🔭 Frontend Analysis

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  analyze:
    name: Analyze Frontend
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: \'20\'
          cache: \'npm\'

      - name: Install dependencies
        run: npm ci

      - name: Make script executable
        run: chmod +x scripts/analyze-frontend.sh

      - name: Run Frontend Analysis
        run: npm run analyze:ci

      - name: Upload Report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: frontend-analysis-report
          path: report.json
          retention-days: 30

      - name: Comment PR
        if: github.event_name == \'pull_request\' && always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require(\'fs\');
            if (!fs.existsSync(\'report.json\')) return;
            const r = JSON.parse(fs.readFileSync(\'report.json\', \'utf8\'));
            const e = r.score >= 90 ? \'✨\' : r.score >= 70 ? \'⚡\' : \'⚠️\';
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `## ${e} Frontend Analysis — Score: ${r.score}/100\\n\\n| | Resultado |\\n|---|---|\\n| 🔴 Erros | ${r.summary.errors} |\\n| 🟡 Avisos | ${r.summary.warnings} |\\n| 🔵 Sugestões | ${r.summary.suggestions} |\\n| ⏱ Tempo | ${r.summary.elapsed_seconds}s |\\n| 🧩 Framework | ${r.framework} |\\n\\n${r.summary.errors > 0 ? \'> ❌ Corrija os erros antes do merge.\' : \'> ✅ Pronto para merge.\'}`
            });
'''

# ── backend/orion-vm-setup.sh ─────────────────────────────────────────────────
files["backend/orion-vm-setup.sh"] = '''#!/usr/bin/env bash
# orion-vm-setup.sh — Diagnóstico da VM Orion (GCP / FastAPI)
# Uso: ./orion-vm-setup.sh

set -euo pipefail
RED=\'\\033[0;31m\'; GREEN=\'\\033[0;32m\'; YELLOW=\'\\033[1;33m\'
CYAN=\'\\033[0;36m\'; BOLD=\'\\033[1m\'; DIM=\'\\033[2m\'; RESET=\'\\033[0m\'

ok()      { echo -e "${GREEN}  ✔${RESET} $1"; }
warn()    { echo -e "${YELLOW}  ⚠${RESET} $1"; }
err()     { echo -e "${RED}  ✖${RESET} $1"; }
section() { echo -e "\\n${BOLD}${CYAN}━━━ $1 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"; }

echo -e "${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}║     ⚙️  Orion VM Diagnostics             ║${RESET}"
echo -e "${BOLD}╚══════════════════════════════════════════╝${RESET}"

section "1. Serviço systemd"
systemctl is-active orion &>/dev/null && ok "orion.service ATIVO" || err "orion.service INATIVO"
systemctl is-enabled orion &>/dev/null && ok "Habilitado no boot" || warn "Não habilitado no boot"

section "2. Variáveis de Ambiente"
ENV_OUTPUT=$(sudo systemctl show orion --property=Environment 2>/dev/null || true)
echo "$ENV_OUTPUT" | grep -oP \'[A-Z_]+=\\S+\' | while IFS= read -r var; do
  KEY=$(echo "$var" | cut -d= -f1)
  [[ ${#KEY} -gt 0 ]] && ok "$KEY definida" || warn "$KEY vazia"
done

section "3. Endpoints FastAPI"
BASE="http://localhost:8080"
for EP in "health" "docs"; do
  CODE=$(curl -s -o /dev/null -w "%{http_code}" "${BASE}/${EP}" 2>/dev/null || echo "000")
  [[ "$CODE" == "200" ]] && ok "/${EP} → ${CODE}" || err "/${EP} → ${CODE}"
done

section "4. Memória"
MEM=$(curl -s "${BASE}/health" 2>/dev/null | python3 -c \
  "import json,sys; d=json.load(sys.stdin); \
   used=d[\'memory_used_mb\']; total=d[\'memory_total_mb\']; \
   pct=round(used/total*100); \
   print(f\'{used}MB / {total}MB ({pct}%)\' )" 2>/dev/null || echo "N/A")
echo -e "  ${DIM}RAM: $MEM${RESET}"

section "5. Drop-ins systemd"
ls /etc/systemd/system/orion.service.d/ 2>/dev/null | while IFS= read -r f; do
  [[ "$f" == *.disabled ]] && warn "$f (desativado)" || ok "$f ativo"
done

section "6. .env"
ENV_PATH="/home/$(logname)/orion-vm-bundle/.env"
[[ -f "$ENV_PATH" ]] && ok ".env encontrado: $ENV_PATH" || err ".env não encontrado"
grep -q "^\.env" "${ENV_PATH%/*}/.gitignore" 2>/dev/null && \
  ok ".env no .gitignore" || warn ".env não está no .gitignore"

echo -e "\\n${GREEN}${BOLD}✨ Diagnóstico concluído.${RESET}\\n"
'''

# ── .gitignore ────────────────────────────────────────────────────────────────
files[".gitignore"] = '''.env
.env.local
.env.*.local
node_modules/
*.log
report.json
dist/
build/
.DS_Store
'''

